		DB PC_KEY_X+49,PC_KEY_Y+11,3,5	; 6B LEFT ARROW
		DB PC_KEY_X+53,PC_KEY_Y+3,3,5	; 6C HOME
		DB 12 DUP 0			; 6D
		DB PC_KEY_X+49,PC_KEY_Y+3,3,5	; 70 INSERT
		DB PC_KEY_X+49,PC_KEY_Y+5,3,5	; 71 DELETE
