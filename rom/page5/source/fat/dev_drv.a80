
; LAST UPDATE: 16.02.2025 savelij

MASTER		EQU 0
SLAVE		EQU 0x80

EXTERNAL	EQU 0			; внешний вызов
INTERNAL	EQU 1			; внутренний вызов
INT4EXT		EQU 3			; внутренний вызов для вызвавшей проги

B_SDZ		EQU %00000001
B_SDG		EQU %00000010
B_HDD		EQU %00000100
B_NEW_SD	EQU %01000000
B_INST_SDG	EQU %10000000

CRC_SIZE	EQU 0xE0

; вызов выбранного драйвера
TO_DRV		PUSH HL
		LD L,A
		LD A,IYL
		AND A
		LD A,L
		JR NZ,TO_DRV1
		CALL P5_READ_BYTE
		LD A,(RREG_A)
		LD DE,(RREG_E)
		LD BC,(RREG_C)
		LD HL,(RREG_L)
		EX (SP),HL
TO_DRV1		LD HL,(DEVMAN_VARS.GO_DEV)
		EX (SP),HL
		RET

; внешний вызов менеджера устройств
COM_DEV		EX AF,AF'
		CALL P5_READ_BYTE
		LD A,(NEXTBYTERST8)
		PUSH IY
		LD IYL,EXTERNAL			; внешний вызов
NEXT_ICOM_DEV	PUSH IX
		PUSH HL
		LD HL,EXITDEV
		EX (SP),HL
		PUSH HL
		ADD A,A
		ADD A,LOW (TABLDEV)
		LD L,A
		ADC A,HIGH (TABLDEV)
		SUB L
		LD H,A
		LD A,(HL)
		INC HL
		LD H,(HL)
		LD L,A
		EX AF,AF'
		EX (SP),HL
		RET

EXITDEV		POP IX
		POP IY
		RET

; внутренний вызов менеджера устройств
ICOM_DEV	EX AF,AF'
		EX (SP),HL
		LD A,(HL)
		INC HL
		EX (SP),HL
		PUSH IY
		LD IYL,INTERNAL			; внутренний вызов
		JR NEXT_ICOM_DEV

TABLDEV		DW DEVFIND			; 00 поиск устройств
		DW SET_VOL			; 01 выбор раздела
		DW KOL_VOL			; 02 запрос найденого
		DW GET_FNDVOLUME		; 03 получить таблицу найденных разделов
		DW TO_DRV			; 04 вызов драйвера выбранного устройства
		DW SET_DEVICE			; 05 установка битов устройства и LBA режима
		DW CONTROL_SD			; 06 контроль наличия SD карт
		DW COMHDDNEX			; 07 прямой вызов драйвера HDD NEMO
		DW FREINIT_VOL			; 08 полная переинициализация раздела
		DW SET_SECTOR_NUM		; 09 установка номера сектора для чтения/записи

; ФОРМАТ ТАБЛИЦЫ НАЙДЕННЫХ РАЗДЕЛОВ
; +0(1)-нумерацию смотреть в сорце nums_devices.a80
; +1(1)-для SD-всегда 0
;       иначе HDD/CD 0-MASTER, 1-SLAVE
; +2(1)-тип раздела, в таблице только
; разделы:
; 00=01-FAT12
; 01=04,06,0E-FAT16
; 02=0B,0C-FAT32
; +3(4)-стартовый сектор раздела
; +7(1)-резерв

; точка входа для поиска разделов
; HL-адрес куда покласть таблицу разделов
; на выходе:
; A-кол-во разделов
DEVFIND		LD A,(DEVMAN_VARS.FLAGS_DRV)
		AND B_NEW_SD
		JR NZ,.L1
		LD HL,CRC_SIZE
		LD IX,BUF_VOLUMES
	ROMCALL CRC16_FAST,ROM_RST81
		LD BC,(BUF_VOLUMES + 0xFE)
		AND A
		SBC HL,BC
		JP Z,KOL_VOL
.L1		LD HL,DEVMAN_VARS.FLAGS_DRV
		LD A,B_NEW_SD!0xFF
		AND (HL)
		LD (HL),A
		PUSH IY
		XOR A
		LD (DEVMAN_VARS.KOLDVOL),A
		LD HL,BUF_VOLUMES
		LD DE,BUF_VOLUMES+1
		LD BC,0xEF
		LD (HL),B
		LDIR
		LD IX,DEVMAN_VARS.DEVICES
		LD IYL,INTERNAL
		LD A,(HDDTIMEOUT)
.L2		EI
		HALT
		HALT
		DI
		DEC A
		JR NZ,.L2
		INC A
		LD (HDDTIMEOUT),A
; NEMO

; ===== test =====
	IFNDEF TESTEMUFDD
		LD HL,BUF_512			; адрес буфера для загрузки сектора (512 байт)
		CALL COMHDDN
		DB _DEV_INIT			; инициализация устройства с определением что подключено
		LD A,H
		AND A
		JR NZ,.L3
		LD (IX+0),_HDD_NEMO_MASTER+MASTER
		INC IX
	ENDIF
; ===== test =====

.L3	
; SD ON NEOGS
		LD H,CMOS.BYTE_01
	ROMCALL READCMOS,ROM_RST82
		LD A,L
		AND CMOS_EC.M_SD_NGS_ONOFF	; проверка разрешения доступа к SD карте NEOGS
		JR Z,.L4			; если запрещен, то не вызываем
		CALL INSTSDD			; уcтановка драйвера SD карты на NEOGS
		AND A
		JR NZ,.L4			; не инициализировать если NEOGS не найден
		LD HL,DEVMAN_VARS.FLAGS_DRV
		SET 7,(HL)			; драйвер установился
		CALL COMSDG
		DB _DEV_INIT			; инициализация SD карты на NEOGS
		AND A
		JR NZ,.L4
		LD (IX+0),_SD_SDG
		INC IX
.L4
; USB FLASH
	IF USB_ENABLE
		CALL COMUSBF
		DB _DEV_INIT
		AND A
		JR Z,.L8
		LD (IX+0),_SL_USBF
		INC IX
	ENDIF
.L8
; SD ON Z-CONTROLLER
		CALL COMSDZ
		DB _DEV_INIT			; инициализация SD карты
		AND A
		JR NZ,.L5
		LD (IX+0),_SD_SDZ
		INC IX
.L5		LD (IX+0),0xFF			; далее нет найденных устройств
		CALL FIND_SD
		LD HL,DEVMAN_VARS.DEVICES
		LD IX,BUF_VOLUMES
		LD A,(HL)
		INC A
		JR Z,.L7
.L6		CALL FINDVOL
		INC HL
		LD A,(HL)
		INC A
		JR NZ,.L6
.L7		CALL SETVOLD			; вычисление количества найденных разделов на всех устройствах
		POP IY
		SCF
		JP Z,KOLVOL1			; переход если ничего не найдено
		DEC A
		LD (DEVMAN_VARS.SETDVOL),A
; ====инициализация переменных всех найденных разделов====
INIT_VOLS	LD IX,BUF_VOLUMES
		LD A,(DEVMAN_VARS.SETDVOL)
		PUSH AF				; сохранили текущий выбранный раздел
		LD A,(DEVMAN_VARS.KOLDVOL)
		LD E,A
		LD D,0
IV_SETDRV2	PUSH AF
		LD A,D
		LD (DEVMAN_VARS.SETDVOL),A
		LD A,(IX+0)
		CP _SD_SDZ
		LD HL,COMSDZ
		JR Z,IV_SETDRV1
		CP _SL_USBF
		LD HL,COMUSBF
		JR Z,IV_SETDRV1
		CP _SD_SDG
		LD HL,COMSDG
		JR Z,IV_SETDRV1
		LD HL,COMHDDN
IV_SETDRV1	LD (DEVMAN_VARS.GO_DEV),HL	; установили адрес текущего вызываемого драйвера
		LD A,(IX+2)
		LD HL,BUF_VOLUMES
		PUSH DE
		CALL ICOM_FAT
		DB _INIT_FATVARS
		PUSH AF
		CALL SAVE_FNDVOL
		POP AF
		POP DE
		CALL C,DEL_VOL			; раздел неизвестен или не отформатирован, удаляем описатель
		INC D
		LD BC,8
		ADD IX,BC
		POP AF
		DEC A
		JR NZ,IV_SETDRV2
; ====инициализация переменных всех найденных разделов====
		POP AF
		CALL SET_VOL1			; восстановление текущего выбранного раздела
		LD A,(DEVMAN_VARS.KOLDVOL)
		DEC A
		CALL C,SET_VOL1			; если выбран не существующий раздел, то принудительно выбираем последний найденный
		CALL ICOM_FAT
		DB _INIT_TEKDIR
		LD HL,CRC_SIZE
		LD IX,BUF_VOLUMES
	ROMCALL CRC16_FAST,ROM_RST81
		LD (BUF_VOLUMES + 0xFE),HL
KOL_VOL		LD A,IYL
		AND A
		JR NZ,IKOL_VOL
		LD HL,(DEVMAN_VARS.ADRTEKV)	; адрес текущего выбранного раздела
		INC HL
		INC HL
		LD A,(HL)			; тип раздела
		LD HL,(DEVMAN_VARS.KOLDVOL)	; D-номер выбранного раздела, E-количество найденных разделов
		LD (RREG_E),HL
		AND A
KOLVOL1		PUSH AF
		POP HL
		LD (RREG_F),HL
		RET

; удаление раздела из таблицы
DEL_VOL		PUSH DE
		PUSH IX
		POP HL
		EX DE,HL
		LD HL,8
		ADD HL,DE
		LD C,L
		LD A,26*8
		SUB C
		LD C,A
		LD B,0
		LDIR
		LD BC,-8
		ADD IX,BC
		LD HL,DEVMAN_VARS.KOLDVOL
		DEC (HL)
		POP DE
		DEC D
		RET

FINDVOL		PUSH HL
		LD A,(HL)
		LD (DEVMAN_VARS.TEK_TYPE),A
		AND 0x7F
		CP _HDD_NEMO_MASTER
		LD HL,COMHDDN
		JR Z,FINDVOL1
		CP _SD_SDG
		LD HL,COMSDG
		JR Z,FINDVOL1
		LD HL,COMSDZ
FINDVOL1	LD (DEVMAN_VARS.GO_DEV),HL	; выставили адрес вызова нужного драйвера
		LD DE,0
		LD B,D
		LD C,D				; читать сектор 0
		LD A,1				; 1 сектор
		LD HL,BUF_512			; адрес буфера чтения
		PUSH HL
		LD IYL,INTERNAL
		CALL TO_DRV
		DB _DEV_READ
		DEC HL
		LD D,(HL)
		DEC HL
		LD E,(HL)
		LD HL,0xAA55
		AND A
		SBC HL,DE
		POP IY
		LD (DEVMAN_VARS.ADRTEKV),IX
		CALL Z,READ_MBR
		POP HL
		RET

; запрос найденого и текущего выбранного устройства
IKOL_VOL	LD HL,(DEVMAN_VARS.ADRTEKV)	; адрес текущего выбранного раздела
		INC HL
		INC HL
		LD A,(HL)			; тип раздела
		LD DE,(DEVMAN_VARS.KOLDVOL)	; D-номер выбранного раздела, E-количество найденных разделов
		LD HL,BUF_VOLUMES		; адрес начала таблицы найденных разделов
		AND A
		RET

; вычисление количества найденных разделов на всех устройствах
SETVOLD		LD A,IXL
		RRCA
		RRCA
		RRCA
		AND 0x1F
		LD (DEVMAN_VARS.KOLDVOL),A
		RET

; выбор раздела и инит его переменных
FREINIT_VOL	LD L,A
		LD A,IYL
		AND A
		JR Z,FREINITVOL1
		LD A,(RREG_A)
FREINITVOL1	LD IYL,INTERNAL
		CALL SET_VOL1
		CALL INIT_FATVARS
		JP INIRTSC

; выбор раздела
SET_VOL		LD L,A
		LD A,IYL
		AND A
		LD A,L
		JR NZ,SET_VOL1
		LD A,(RREG_A)
		LD HL,KOLVOL1
		PUSH HL
SET_VOL1	PUSH AF
		CALL SAVE_FNDVOL
		POP AF
SET_VOL_MNT	LD HL,DEVMAN_VARS.KOLDVOL
		CP (HL)
		CCF
		RET C
		LD (DEVMAN_VARS.SETDVOL),A
		LD L,A
		LD H,0
		ADD HL,HL
		ADD HL,HL
		ADD HL,HL
		LD DE,BUF_VOLUMES
		ADD HL,DE
		LD (DEVMAN_VARS.ADRTEKV),HL
		LD A,(HL)
;		CP 4
;		LD HL,DISKETA		; все еще отсутствует
;		JR C,SET_DRV
		CP _SL_USBF
		LD HL,COMUSBF
		JR Z,SET_DRV
		CP _SD_SDZ
		LD HL,COMSDZ
		JR Z,SET_DRV
		CP _SD_SDG
		LD HL,COMSDG
		JR Z,SET_DRV
		LD HL,COMHDDN
SET_DRV		LD (DEVMAN_VARS.GO_DEV),HL
		CALL LOAD_FNDVOL
.L1		LD HL,CRC_SIZE
		PUSH IX
		LD IX,BUF_VOLUMES
	ROMCALL CRC16_FAST,ROM_RST81
		POP IX
		LD (BUF_VOLUMES + 0xFE),HL
		XOR A
		RET

SAVE_FNDVOL
;		PUSH IX
;		LD HL,CRC_SIZE
;		LD IX,FATVAR.ERORDRV
;	ROMCALL CRC16_FAST,ROM_RST81
;		POP IX
;		LD (BUF_VOLUMES + 0xFE),HL	; вычисление CRC раздела перед сохранением
	EVOPORT WIN_P1,RAM_FATVARS
		LD A,(DEVMAN_VARS.SETDVOL)
		ADD A,HIGH (CPU1+BUF_ALLVOL)+4
		LD D,A
		LD E,0
		LD HL,BUF_CURRFATVAR
		LD BC,0x100
		LDIR
		RET

LOAD_FNDVOL
	EVOPORT WIN_P1,RAM_FATVARS
		LD A,(DEVMAN_VARS.SETDVOL)
		ADD A,HIGH (CPU1+BUF_ALLVOL)+4
		LD H,A
		LD L,0
		LD DE,BUF_CURRFATVAR
		LD BC,0x100
		LDIR
;		PUSH IX
;		LD HL,CRC_SIZE
;		LD IX,BUF_VOLUMES
;	ROMCALL CRC16_FAST,P_ADDON1
;		POP IX
;		LD DE,(BUF_VOLUMES + 0xFE)
;		AND A
;		SBC HL,DE
;		JP NZ,REDEVFIND
		CALL ICOM_FAT
		DB _INIT_TEKDIR
		RET

CMP_SDCARD	LD A,(DEVMAN_VARS.SETDVOL)
		CP _SD_SDG
		JR NZ,CMPSDCARD1
		LD H,CMOS.BYTE_01
	ROMCALL READCMOS,ROM_RST82
		LD A,L
		AND CMOS_EC.M_SD_NGS_ONOFF	; проверка разрешения доступа к SD карте NEOGS
		RET Z
CMPSDCARD1	PUSH IY
		LD IYL,INTERNAL
		CALL TO_DRV
		DB _DEV_STATUS
		POP IY
		INC A
		RET

READ_MBR	LD DE,0x01BE			; смещение в 0 секторе устройства до таблицы MBR
		PUSH IY
		ADD IY,DE			; установили указатель на начало описателей разделов
		LD BC,0x0400			; разделов максимум 4 и обнулили счетчик разделов с FAT
.L1		LD A,(IY)			; первый байт 16 байтного описателя
		AND A				; должен быть равен 0
		JR Z,.L2
		CP 0x80				; или 0x80 (признак загрузочного раздела)
		JR NZ,.L3
.L2		LD A,(IY+4)			; байт типа раздела
		CALL CP_RAZD			; проверка типа раздела
		JR NZ,.L3			; если не FAT то проверяем следующую 16 байтную запись
		INC C
.L3		LD DE,0x10
		ADD IY,DE
		DJNZ .L1			; проверяем следующую 16 байтную запись в MBR
		LD A,C
		AND A
		POP HL
		JP NZ,SCANMBR
		PUSH HL
		POP IY
		LD C,(IY+0x0D)
		XOR A
		LD E,A
		LD B,8
.L4		RR C
		ADC A,0
		DJNZ .L4
		DEC A
		JR NZ,.L5
		INC E
.L5		LD A,(IY+0x0E)
		OR (IY+0x0F)
		JR Z,.L10
		INC E
.L10
;		LD A,(IY+0x13)
;		OR (IY+0x14)
;		JR Z,.L6
;		INC E
;.L6		LD A,(IY+0x20)
;		OR (IY+0x21)
;		OR (IY+0x22)
;		OR (IY+0x22)
;		JR Z,.L7
;		INC E
.L7		LD A,(IY+0x15)
		AND 0xF0
		CP 0xF0
		JR NZ,.L8
		INC E
.L8		LD A,E
		CP 3;4
		RET NZ
		LD A,(DEVMAN_VARS.TEK_TYPE)
		BIT 7,A
		LD B,0
		JR Z,.L9
		INC B
.L9		AND 0x7F
		LD C,A
		PUSH IX
		POP HL
		XOR A
		LD (HL),C
		INC HL
		LD (HL),B
		INC HL
		LD (HL),0xFF
		INC HL
		LD (HL),A
		INC HL
		LD (HL),A
		INC HL
		LD (HL),A
		INC HL
		LD (HL),A
		INC HL
		LD (HL),A
		LD DE,8
		ADD IX,DE
INIT_VOL	PUSH IY
		LD IYL,INTERNAL
		CALL SETVOLD
		DEC A
		LD (DEVMAN_VARS.SETDVOL),A
		LD L,A
		LD H,0
		ADD HL,HL
		ADD HL,HL
		ADD HL,HL
		LD DE,BUF_VOLUMES
		ADD HL,DE
		LD (DEVMAN_VARS.ADRTEKV),HL
		LD A,(HL)
		AND 0x7F
;		CP 4
;		LD HL,DISKETA		; все еще отсутствует
;		JR C,DSET_DRV
		CP _SL_USBF
		LD HL,COMUSBF
		JR Z,DSET_DRV
		CP _SD_SDZ
		LD HL,COMSDZ
		JR Z,DSET_DRV
		CP _SD_SDG
		LD HL,COMSDG
		JR Z,DSET_DRV
		LD HL,COMHDDN
DSET_DRV	LD (DEVMAN_VARS.GO_DEV),HL
		CALL IKOL_VOL
		CALL ICOM_FAT
		DB _INIT_FATVARS
		LD (IX-6),A
		POP IY
		RET

; на входе:
; A-BIT 7-0/1-MASTER/SLAVE
; биты 6-0-тип носителя
SCANMBR		LD DE,0x01BE
		ADD HL,DE
		EXX
		LD A,(DEVMAN_VARS.TEK_TYPE)
		BIT 7,A
		LD B,0
		JR Z,.L4
		INC B
.L4		AND 0x7F
		LD C,A
		EXX
		LD A,4
.L1		PUSH AF
		LD A,(HL)
		LD C,4
		ADD HL,BC
		LD C,0x0C
		AND A
		JR Z,.L2
		CP 0x80
		JR NZ,.L3
.L2		LD A,(HL)
		AND A
		JR Z,.L3
		CALL CP_RAZD
		JR NZ,.L3
		EXX
		LD (IX+0),C
		LD (IX+1),B
		EXX
		LD (IX+2),E			; установка типа FAT
		PUSH IX
		POP DE
		INC DE
		INC DE
		INC DE
		LD C,4
		ADD HL,BC
		LDI
		LDI
		LDI
		LDI
		LD (IX+7),0			; резервный байт
		LD C,8
		ADD IX,BC
		LD C,4
.L3		ADD HL,BC
		POP AF
		DEC A
		JR NZ,.L1
		RET

SET_DEVICE	PUSH AF
		PUSH HL
		LD A,B
		AND 0x0F
		LD B,A
		LD HL,(DEVMAN_VARS.ADRTEKV)
		INC HL
		LD A,(HL)
		AND 1				;MASTER или SLAVE?
		RLCA
		RLCA
		RLCA
		RLCA
		OR 0xE0				; всегда LBA режим
		OR B
		LD B,A				; установили выбранное устройство MASTER или SLAVE
		POP HL
		POP AF
		RET

; проверка типа раздела
CP_RAZD		LD E,1				; FAT16
		CP 4
		RET Z
		CP 6
		RET Z
		CP 0x0E
		RET Z
		LD E,2				; FAT32
		CP 0x0B
		RET Z
		CP 0x0C
		RET Z
		LD E,0				; FAT12
		CP 1
		RET

; функция вызова драйвера HDD NEMO
COMHDDNEX	CALL P5_READ_BYTE
		LD A,(RREG_AA)
		EX AF,AF'
		LD A,(RREG_A)
		LD DE,(RREG_E)
		LD BC,(RREG_C)
		LD HL,(RREG_L)
		CALL COMHDDN
		LD (RREG_A),A
		LD (RREG_L),HL
		LD (RREG_E),DE
		LD (RREG_C),BC
		RET

; копирование таблицы найденных разделов во внешнюю программу
GET_FNDVOLUME	LD BC,0x100			; перенос 256 байт
		LD DE,(RREG_L)			; адрес куда переносить
		LD HL,BUF_VOLUMES & 0x3FFF;BUF_TABLVOL-CPU2
		JP LDIR_BYTES

CONTROL_SD	LD A,(DEVMAN_VARS.FLAGS_DRV)
		PUSH AF
		CALL FIND_SD
		LD C,A
		AND 3
		LD (RREG_A),A
		LD A,C
		POP BC
		CP B
		JP NZ,SD_CARD_LOST
		RET

FIND_SD		PUSH IY
		LD IYL,INTERNAL
		LD E,0
		LD A,(DEVMAN_VARS.FLAGS_DRV)
		AND B_INST_SDG
		JR Z,CRTLSD1			; если драйвер не установлен
		PUSH HL
		PUSH DE
		CALL COMSDG
		DB _DEV_STATUS
		POP DE
		POP HL
		AND A
		SET 1,E				; есть SD карта NEOGS
		JR Z,CRTLSD1
		RES 1,E				; карты нет
		EX DE,HL
		LD HL,DEVMAN_VARS.FLAGS_DRV
		RES 7,(HL)
		EX DE,HL
CRTLSD1		PUSH HL
		CALL COMSDZ
		DB _DEV_STATUS
		POP HL
		AND A
		SET 0,E				; есть SD карты ZC
		JR Z,CRTLSD2
		RES 0,E				; карты нет
CRTLSD2		POP IY
		LD HL,DEVMAN_VARS.FLAGS_DRV
		LD A,%11111100
		AND (HL)
		OR E
		LD (HL),A
		RET

; HLBCDE - номер сектора
SET_SECTOR_NUM
		LD HL,(RREG_L)
		LD (NUMSEC_LBA48+4),HL
		LD HL,(RREG_C)
		LD (NUMSEC_LBA48+2),HL
		LD HL,(RREG_E)
		LD (NUMSEC_LBA48),HL
		RET
